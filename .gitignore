# Secrets and sensitive configuration
config/secrets.json
.env
.env.local
*.env

# Credentials and cookies
data/cookies/
~/.openclaw/credentials/
*.cookies.json

# Log files
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# Build artifacts
*.pdf
*.tex.backup

# OpenClaw runtime
.openclaw/
*.state.json

