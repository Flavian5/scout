data/leads/*.json
!data/leads/.gitkeep
applications/*/

# Node modules (if any skill implementations use Node)
node_modules/

# Python cache
__pycache__/
*.pyc
.pytest_cache/

# Temporary files
tmp/
temp/
*.tmp

# Claw files
.clawhub/

# Vscode
.vscode/