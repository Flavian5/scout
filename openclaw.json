{
  "version": "3.0.0",
  "description": "OpenClaw configuration for Scout Personal Assistant",
  "workspace": {
    "path": ".",
    "name": "scout"
  },
  "agents": {
    "defaults": {
      "sandbox": {
        "mode": "non-main"
      },
      "model": {
        "primary": "MiniMax-M2.7",
        "base_url": "https://api.minimax.io/v1",
        "endpoint": "https://api.minimax.io/v1/text/chatcompletion_v2"
      },
      "heartbeat": {
        "every": "30m",
        "at": "00,30"
      }
    }
  },
  "skills": {
    "entries": {
      "email-check": {
        "enabled": true
      },
      "signal-detector": {
        "enabled": true,
        "config": {
          "model": "MiniMax-M2.7",
          "provider": "minimax.io",
          "endpoint": "https://api.minimax.io/v1/text/chatcompletion_v2"
        }
      },
      "ddg-web-search": {
        "enabled": true
      },
      "openclaw-tavily-search": {
        "enabled": true,
        "config": {
          "api_key": "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"
        }
      },
      "discord-bot": {
        "enabled": true
      }
    }
  },
  "notifications": {
    "enabled": true,
    "channel": "email",
    "method": "smtp",
    "schedule": "8 3 * * *",
    "template": "daily_heartbeat"
  },
  "logging": {
    "level": "info",
    "file": "logs/openclaw.log",
    "console": true
  },
  "secrets": {
    "path": "config/secrets.json",
    "required": [
      "llm_api.api_key"
    ]
  }
}