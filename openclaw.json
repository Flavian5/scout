{
  "version": "2.0.0",
  "description": "OpenClaw configuration for Autonomous Job Search Assistant",
  "workspace": {
    "path": ".",
    "name": "scout"
  },
  "agents": {
    "defaults": {
      "sandbox": {
        "mode": "non-main"
      },
      "model": {
        "primary": "openrouter/minimax/minimax-m2.5" 
      },
      "heartbeat": {
        "every": "24h",
        "at": "02:00"
      }
    },
    "scout": {
      "enabled": true,
      "schedule": "0 2 * * *",
      "input_files": [
        "config/sourcing.json",
        "config/criteria.json",
        "config/persona.md"
      ],
      "output_files": [
        "data/leads/raw_leads.json"
      ]
    },
    "analyst": {
      "enabled": true,
      "schedule": "30 2 * * *",
      "input_files": [
        "data/leads/raw_leads.json",
        "config/criteria.json",
        "config/persona.md"
      ],
      "output_files": [
        "data/leads/enriched_leads.json"
      ]
    },
    "strategist": {
      "enabled": true,
      "schedule": "0 3 * * *",
      "input_files": [
        "data/leads/enriched_leads.json",
        "config/persona.md",
        "data/cv_base.md",
        "data/cover_letter_base.md"
      ],
      "output_dir": "applications"
    }
  },
  "skills": {
    "entries": {
      "linkedin-scout": {
        "enabled": true,
        "config": {
          "requires_auth": true,
          "cookies_path": "~/.openclaw/skills/linkedin-scout/cookies.json"
        }
      },
      "wellfound-scout": {
        "enabled": true,
        "config": {
          "requires_auth": false
        }
      },
      "signal-detector": {
        "enabled": true,
        "config": {
          "model": "minimax/minimax-m2.5",
          "provider": "openrouter"
        }
      },
      "asset-generator": {
        "enabled": true,
        "config": {
          "templates_dir": "data",
          "output_dir": "applications"
        }
      },
      "company-research": {
        "enabled": true
      },
      "tavily-search": {
        "enabled": true,
        "config": {
          "api_key": "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"
        }
      },
      "career-page-scout": {
        "enabled": true
      },
      "ats-scout": {
        "enabled": true
      }
    }
  },
  "notifications": {
    "enabled": true,
    "channel": "email",
    "method": "smtp",
    "schedule": "8 3 * * *",
    "template": "daily_heartbeat"
  },
  "logging": {
    "level": "info",
    "file": "logs/openclaw.log",
    "console": true
  },
  "secrets": {
    "path": "config/secrets.json",
    "required": [
      "linkedin.li_at",
      "linkedin.jsessionid",
      "llm_api.api_key"
    ]
  },
  "paths": {
    "persona": "config/persona.md",
    "sourcing": "config/sourcing.json",
    "criteria": "config/criteria.json",
    "leads": "data/leads",
    "applications": "applications",
    "templates": "data"
  }
}