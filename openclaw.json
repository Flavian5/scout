{
  "version": "3.0.0",
  "description": "OpenClaw configuration for Scout Personal Assistant",
  "workspace": {
    "path": ".",
    "name": "scout"
  },
  "agents": {
    "defaults": {
      "sandbox": {
        "mode": "non-main"
      },
      "model": {
        "primary": "MiniMax-M2.7",
        "base_url": "https://api.minimax.io/v1",
        "endpoint": "https://api.minimax.io/v1/text/chatcompletion_v2"
      },
      "heartbeat": {
        "every": "30m",
        "at": "00,30"
      }
    }
  },
  "skills": {
    "entries": {
      "signal-detector": {
        "enabled": true,
        "config": {
          "model": "MiniMax-M2.7",
          "provider": "minimax.io",
          "endpoint": "https://api.minimax.io/v1/text/chatcompletion_v2"
        }
      },
      "gog": {
        "enabled": true
      },
      "discord-bot": {
        "enabled": true
      },
      "email-alerts": {
        "enabled": true
      },
      "calendar-confirm": {
        "enabled": true
      },
      "notion": {
        "enabled": true,
        "config": {
          "databases": [
            "chores",
            "financials",
            "projects",
            "weekend-plans",
            "daily-briefing",
            "research",
            "knowledge-base",
            "deliverables"
          ]
        }
      }
    }
  },
  "notifications": {
    "enabled": true,
    "channel": "email",
    "method": "smtp",
    "schedule": "8 3 * * *",
    "template": "daily_heartbeat"
  },
  "logging": {
    "level": "info",
    "file": "logs/openclaw.log",
    "console": true
  },
  "secrets": {
    "path": "config/secrets.json",
    "required": [
      "llm_api.api_key"
    ]
  },
  "hooks": {
    "workspace": {
      "enabled": true,
      "path": "hooks",
      "auto_reload": true
    },
    "discord-commands": {
      "enabled": true,
      "path": "hooks/discord-commands",
      "events": ["discord.command", "discord.message"]
    }
  }
}
