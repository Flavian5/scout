# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# Webhook URL to forward incoming Discord messages to
# For local dev, this is the scout webhook server
OPENCLAW_WEBHOOK_URL=http://localhost:3001/discord/in

# HTTP server port (default: 3456)
PORT=3456

# Logging level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Comma-separated channel IDs to listen to (empty = all channels)
# LISTEN_CHANNELS=123456789,987654321

# Ignore messages from other bots (default: true)
IGNORE_BOTS=true