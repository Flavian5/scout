{
  "version": "3.0.0",
  "description": "Scoring criteria for job role evaluation - balances AI-centrality, resilience, comp, career impact, and technical alignment",
  "scoring_model": {
    "description": "Weighted scoring model for evaluating job opportunities against persona preferences",
    "max_score": 100,
    "passing_threshold": 70,
    "high_priority_threshold": 85
  },
  "categories": {
    "ai_criticality": {
      "weight": 20,
      "description": "How central AI/ML is to the company's product - product IS the model",
      "signals": [
        {
          "name": "product_is_model",
          "keywords": ["autonomous", "self-driving", "drug discovery", "foundation model", "LLM product", "generative AI product"],
          "points": 25,
          "notes": "Product IS the model - highest AI centrality"
        },
        {
          "name": "ai_core_moat",
          "keywords": ["perception", "computer vision", "recommendation engine", "recsys", "personalization engine", "generative recommendation"],
          "points": 20,
          "notes": "AI is the competitive moat"
        },
        {
          "name": "ai_infrastructure",
          "keywords": ["ML platform", "feature store", "model serving", "training infrastructure", "ML pipeline", "MLOps"],
          "points": 15,
          "notes": "Building AI infrastructure for others"
        },
        {
          "name": "ai_research_lab",
          "keywords": ["research scientist", "AI lab", "OpenAI", "DeepMind", "Anthropic", "researcher"],
          "points": 18,
          "notes": "Pure AI research organization"
        }
      ]
    },
    "resilience": {
      "weight": 15,
      "description": "Sector resilience - funding stability regardless of economic cycles",
      "signals": [
        {
          "name": "defense_national_security",
          "keywords": ["defense", "national security", "intelligence", "autonomous systems", "Palantir", "Anduril", "Lockheed", "military"],
          "points": 25,
          "notes": "Defense spending is counter-cyclical"
        },
        {
          "name": "mandatory_compliance",
          "keywords": ["tax", "regulatory", "compliance", "payroll", "accounting software", "turbotax"],
          "points": 20,
          "notes": "Mandatory software with high switching costs"
        },
        {
          "name": "critical_infrastructure",
          "keywords": ["grid", "energy", "power", "semiconductor", "manufacturing", "supply chain"],
          "points": 20,
          "notes": "Critical infrastructure - hard to cut"
        },
        {
          "name": "healthcare_core",
          "keywords": ["drug discovery", "clinical trials", "medical imaging", "hospital operations", "biotech", "pharma"],
          "points": 18,
          "notes": "Healthcare is structurally stable"
        },
        {
          "name": "sticky_b2b",
          "keywords": ["enterprise", "infrastructure", "platform", "B2B", "SaaS"],
          "points": 12,
          "notes": "Enterprise software has high retention"
        }
      ]
    },
    "compensation": {
      "weight": 25,
      "description": "Compensation package - base salary, equity, bonuses",
      "signals": [
        {
          "name": "competitive_salary",
          "keywords": ["$250k", "$300k", "$350k", "250k", "300k", "350k", "competitive compensation"],
          "points": 20,
          "notes": "Strong base salary for Staff/Senior level"
        },
        {
          "name": "equity_include",
          "keywords": ["equity", "stock", "RSU", "options", "ownership"],
          "points": 15,
          "notes": "Equity component included"
        },
        {
          "name": "signing_bonus",
          "keywords": ["signing bonus", "relocation", "bonus"],
          "points": 10,
          "notes": "Additional compensation elements"
        }
      ]
    },
    "ml_architecture_depth": {
      "weight": 20,
      "description": "Technical depth of ML systems - focus on sophisticated architectures",
      "signals": [
        {
          "name": "foundation_models",
          "keywords": ["scGPT", "Geneformer", "scPRINT", "foundation model", "pretraining", "large language model", "LLM"],
          "points": 25,
          "notes": "Foundation model experience"
        },
        {
          "name": "transformer_architectures",
          "keywords": ["transformer", "self-attention", "multi-head attention", "BERT", "encoder", "attention mechanism"],
          "points": 22,
          "notes": "Core transformer experience"
        },
        {
          "name": "generative_recommendation",
          "keywords": ["generative recommendation", "GenRec", "VAE", "diffusion model", "flow-based", "autoregressive"],
          "points": 22,
          "notes": "Generative ML for recommendation"
        },
        {
          "name": "two_stage_ranking",
          "keywords": ["candidate generation", "re-ranking", "two-stage", "retrieval", "ranking model", "learned sparse"],
          "points": 20,
          "notes": "Twitter-scale ranking systems"
        },
        {
          "name": "causal_ml",
          "keywords": ["causal inference", "uplift modeling", "treatment effect", "counterfactual", "SCM", "do-calculus"],
          "points": 18,
          "notes": "Causal reasoning for ML"
        },
        {
          "name": "production_ml",
          "keywords": ["feature store", "model serving", "ML pipeline", "MLOps", "A/B testing", "online learning"],
          "points": 15,
          "notes": "Standard production ML"
        }
      ]
    },
    "domain_alignment": {
      "weight": 20,
      "description": "How well the domain aligns with career transition goals",
      "signals": [
        {
          "name": "recsys",
          "keywords": ["recommendation", "personalization", "feed", "discovery", "content ranking", "recsys", "recommender"],
          "points": 25,
          "notes": "Direct RecSys alignment - high priority"
        },
        {
          "name": "virtual_cell",
          "keywords": ["virtual cell", "AI for science", "biological", "single-cell", "omics", "drug discovery", "biotech"],
          "points": 23,
          "notes": "Direct alignment with virtual cell transition"
        },
        {
          "name": "bio_ai",
          "keywords": ["bio-AI", "computational biology", "genomics", "proteomics", "transcriptomics", "phenomics"],
          "points": 21,
          "notes": "Bio-AI domain experience"
        },
        {
          "name": "voice_agent_automation",
          "keywords": ["voice agent", "voice AI", "conversational AI", "voice assistant", "CX automation", "customer experience"],
          "points": 20,
          "notes": "Voice agent / CX automation"
        },
        {
          "name": "healthcare_ai",
          "keywords": ["healthcare ML", "medical AI", "clinical ML", "patient data", "EHR", "clinical trials"],
          "points": 18,
          "notes": "Healthcare domain - relevant background"
        }
      ]
    },
    "career_impact": {
      "weight": 15,
      "description": "Long-term career value - learning, network, mission",
      "signals": [
        {
          "name": "scientific_impact",
          "keywords": ["drug discovery", "therapeutic", "patient outcomes", "biology", "scientific discovery", "research"],
          "points": 20,
          "notes": "Direct contribution to science/health"
        },
        {
          "name": "hyperscale_distributed_compute",
          "keywords": ["hyperscale", "distributed", "petabyte", "large scale", "distributed training", "large scale systems"],
          "points": 20,
          "notes": "Hyperscale / distributed compute experience"
        },
        {
          "name": "publication_opportunity",
          "keywords": ["publish", "academic", "conference", "open source", "research", "paper"],
          "points": 15,
          "notes": "Ability to publish work"
        },
        {
          "name": "leadership_growth",
          "keywords": ["staff", "senior", "lead", "mentor", "team building", "architecture"],
          "points": 15,
          "notes": "Staff+ level scope"
        },
        {
          "name": "cutting_edge",
          "keywords": ["cutting edge", "state of the art", "SOTA", "research", "innovation"],
          "points": 15,
          "notes": "Innovative technical environment"
        }
      ]
    },
    "infrastructure_resources": {
      "weight": 5,
      "description": "Technical infrastructure and compute resources available",
      "signals": [
        {
          "name": "gpu_compute",
          "keywords": ["GPU", "H100", "A100", "V100", "TPU", "NVIDIA", "distributed training"],
          "points": 15,
          "notes": "Access to modern GPU clusters"
        },
        {
          "name": "data_scale",
          "keywords": ["petabyte", "large scale", "billions", "massive data", "data infrastructure"],
          "points": 12,
          "notes": "Large-scale data operations"
        },
        {
          "name": "ml_platform",
          "keywords": ["ML platform", "feature store", "model registry", "MLOps", "Kubeflow"],
          "points": 10,
          "notes": "Mature ML platform"
        }
      ]
    },
    "company_culture": {
      "weight": 5,
      "description": "Company characteristics and work environment",
      "signals": [
        {
          "name": "mission_driven",
          "keywords": ["mission", "impact", "purpose", "non-profit", "foundation", "health"],
          "points": 10,
          "notes": "Mission-driven organization (CZI, Arc, etc.)"
        },
        {
          "name": "remote_friendly",
          "keywords": ["remote", "hybrid", "async", "distributed team"],
          "points": 8,
          "notes": "Flexible work arrangements"
        },
        {
          "name": "technical_leadership",
          "keywords": ["CTO", "VP Eng", "technical", "engineering culture", "tech-first"],
          "points": 8,
          "notes": "Technically sophisticated leadership"
        }
      ]
    },
    "location_requirements": {
      "weight": 5,
      "description": "Location and visa considerations",
      "signals": [
        {
          "name": "bay_area",
          "keywords": ["San Francisco", "Palo Alto", "Menlo Park", "Mountain View", "Sunnyvale", "San Jose"],
          "points": 5,
          "notes": "SF Bay Area location"
        },
        {
          "name": "seattle",
          "keywords": ["Seattle", "Redmond", "Bellevue", "Kirkland"],
          "points": 5,
          "notes": "Seattle area location"
        },
        {
          "name": "remote_us",
          "keywords": ["remote", "US timezone", "Pacific time", "ET"],
          "points": 5,
          "notes": "Remote US-based role"
        },
        {
          "name": "tn_visa",
          "keywords": ["TN", "Canadian", "visa sponsorship"],
          "points": 5,
          "notes": "TN visa eligible"
        }
      ]
    },
    "level_alignment": {
      "weight": 10,
      "description": "Level matching based on company tier - Tier 1 accepts Senior, Tier 2+ requires Staff+",
      "tier_rules": {
        "tier1_ai_critical": {
          "description": "AI-critical companies (defense autonomy, bio-AI, foundation labs)",
          "accept_levels": ["Senior", "Staff", "Principal"],
          "level_bonus": 5,
          "target_companies": ["Anduril", "Shield AI", "Recursion", "Insitro", "OpenAI", "Anthropic", "Cohere", "Waymo", "Zoox", "Aurora", "CoreWeave", "Lambda Labs"]
        },
        "tier2_resilient": {
          "description": "Resilient sectors (tax software, Palantir, CZI, enterprise)",
          "required_level": "Staff",
          "level_bonus": 0,
          "target_companies": ["Intuit", "Palantir", "CZI", "Chan Zuckerberg", "Salesforce", "ServiceNow"]
        },
        "tier3_other": {
          "description": "Other resilient but not AI-critical (banks, energy)",
          "required_level": "Staff",
          "level_penalty": -5,
          "target_companies": ["Capital One", "JPMorgan", "Goldman", "Shell", "BP", "Exxon"]
        }
      },
      "signals": [
        {
          "name": "senior_level",
          "keywords": ["Senior", "Staff", "Principal", "Lead"],
          "points": 10,
          "notes": "Senior-level role or above"
        },
        {
          "name": "staff_level",
          "keywords": ["Staff", "Principal"],
          "points": 15,
          "notes": "Staff or Principal level"
        }
      ]
    }
  },
  "bonus_signals": {
    "description": "Additional points for exceptional alignment",
    "bonuses": [
      {
        "name": "recsys_expertise",
        "keywords": ["recommendation system", "recommender", "personalization", "recsys", "two-stage", "candidate generation"],
        "bonus_points": 12,
        "notes": "RecSys expertise - high value"
      },
      {
        "name": "scverse_experience",
        "keywords": ["Scanpy", "AnnData", "scvi-tools", "scverse", "single-cell"],
        "bonus_points": 10,
        "requires_category": "virtual_cell"
      },
      {
        "name": "agentic_ai",
        "keywords": ["agent", "MCP", "Model Context Protocol", "autonomous", "agentic"],
        "bonus_points": 8,
        "notes": "Scientific AI agents experience"
      },
      {
        "name": "mle_platform_building",
        "keywords": ["ML platform", "ML infrastructure", "data platform", "feature platform"],
        "bonus_points": 5,
        "notes": "Platform building experience"
      }
    ]
  },
  "filter_rules": {
    "description": "Hard filters that immediately disqualify roles",
    "hard_no": [
      {
        "name": "rule_based_only",
        "exclude_keywords": ["rule-based", "heuristic only", "no ML", "manual"],
        "reason": "Requires ML depth, not rule-based systems"
      },
      {
        "name": "non_technical_leadership",
        "exclude_keywords": ["non-technical manager", "non-technical lead"],
        "reason": "Needs technically sophisticated leadership"
      },
      {
        "name": "no_compute_budget",
        "exclude_keywords": ["no GPU", "CPU only", "limited compute"],
        "reason": "Requires compute resources for ML work"
      }
    ],
    "soft_no": [
      {
        "name": "testing_only",
        "exclude_keywords": ["A/B testing only", "experimentation only", "no model development"],
        "reason": "Want model development, not just testing"
      }
    ]
  },
  "output_schema": {
    "description": "Standard output format for scored leads",
    "fields": [
      "job_id",
      "company",
      "role_title",
      "location",
      "application_url",
      "raw_jd_text",
      "detected_signals",
      "category_scores",
      "total_score",
      "meets_threshold",
      "priority_level",
      "recommended_actions"
    ]
  }
}