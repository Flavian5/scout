{
  "version": "1.0.0",
  "description": "Scoring criteria for job role evaluation - de-emphasizes immediate comp, prioritizes impact and value",
  "scoring_model": {
    "description": "Weighted scoring model for evaluating job opportunities against persona preferences",
    "max_score": 100,
    "passing_threshold": 70,
    "high_priority_threshold": 85
  },
  "categories": {
    "ml_architecture_depth": {
      "weight": 25,
      "description": "Technical depth of ML systems - focus on sophisticated architectures over simple A/B testing",
      "signals": [
        {
          "name": "foundation_models",
          "keywords": ["scGPT", "Geneformer", "scPRINT", "foundation model", "pretraining", "large language model", "LLM"],
          "points": 25,
          "notes": "Highest priority - foundation model experience"
        },
        {
          "name": "transformer_architectures",
          "keywords": ["transformer", "self-attention", "multi-head attention", "BERT", "encoder", "attention mechanism"],
          "points": 22,
          "notes": "Core transformer experience"
        },
        {
          "name": "generative_recommendation",
          "keywords": ["generative recommendation", "GenRec", "VAE", "diffusion model", "flow-based", "autoregressive"],
          "points": 22,
          "notes": "Generative ML for recommendation"
        },
        {
          "name": "two_stage_ranking",
          "keywords": ["candidate generation", "re-ranking", "two-stage", "retrieval", "ranking model", "learned sparse"],
          "points": 20,
          "notes": "Twitter-scale ranking systems"
        },
        {
          "name": "causal_ml",
          "keywords": ["causal inference", "uplift modeling", "treatment effect", "counterfactual", "SCM", "do-calculus"],
          "points": 18,
          "notes": "Causal reasoning for ML"
        },
        {
          "name": "production_ml",
          "keywords": ["feature store", "model serving", "ML pipeline", "MLOps", "A/B testing", "online learning"],
          "points": 15,
          "notes": "Standard production ML - less weight than architecture"
        }
      ]
    },
    "domain_alignment": {
      "weight": 25,
      "description": "How well the domain aligns with career transition goals",
      "signals": [
        {
          "name": "virtual_cell",
          "keywords": ["virtual cell", "AI for science", "biological", "single-cell", "omics", "drug discovery", "biotech"],
          "points": 25,
          "notes": "Direct alignment with virtual cell transition"
        },
        {
          "name": "bio_ai",
          "keywords": ["bio-AI", "computational biology", "genomics", "proteomics", "transcriptomics", "phenomics"],
          "points": 23,
          "notes": "Bio-AI domain experience"
        },
        {
          "name": "healthcare_ai",
          "keywords": ["healthcare ML", "medical AI", "clinical ML", "patient data", "EHR", "clinical trials"],
          "points": 18,
          "notes": "Healthcare domain - relevant background"
        },
        {
          "name": "consumer_recsys",
          "keywords": ["recommendation", "personalization", "feed", "discovery", "content ranking"],
          "points": 15,
          "notes": "Traditional consumer RecSys - acceptable but lower priority"
        }
      ]
    },
    "career_impact": {
      "weight": 20,
      "description": "Long-term career value - learning, network, mission (emphasized over immediate TC)",
      "signals": [
        {
          "name": "scientific_impact",
          "keywords": ["drug discovery", "therapeutic", "patient outcomes", "biology", "scientific discovery", "research"],
          "points": 20,
          "notes": "Direct contribution to science/health"
        },
        {
          "name": "publication_opportunity",
          "keywords": ["publish", "academic", "conference", "open source", "research", "paper"],
          "points": 18,
          "notes": "Ability to publish work"
        },
        {
          "name": "leadership_growth",
          "keywords": ["staff", "principal", "senior", "lead", "mentor", "team building", "architecture"],
          "points": 15,
          "notes": "Staff+ level scope"
        },
        {
          "name": "cutting_edge",
          "keywords": ["cutting edge", "state of the art", "SOTA", "research", "innovation"],
          "points": 15,
          "notes": "Innovative technical environment"
        }
      ]
    },
    "infrastructure_resources": {
      "weight": 15,
      "description": "Technical infrastructure and compute resources available",
      "signals": [
        {
          "name": "gpu_compute",
          "keywords": ["GPU", "H100", "A100", "V100", "TPU", "NVIDIA", "distributed training"],
          "points": 15,
          "notes": "Access to modern GPU clusters"
        },
        {
          "name": "data_scale",
          "keywords": ["petabyte", "large scale", "billions", "massive data", "data infrastructure"],
          "points": 12,
          "notes": "Large-scale data operations"
        },
        {
          "name": "ml_platform",
          "keywords": ["ML platform", "feature store", "model registry", "MLOps", "Kubeflow"],
          "points": 10,
          "notes": "Mature ML platform"
        }
      ]
    },
    "company_culture": {
      "weight": 10,
      "description": "Company characteristics and work environment",
      "signals": [
        {
          "name": "mission_driven",
          "keywords": ["mission", "impact", "purpose", "non-profit", "foundation", "health"],
          "points": 10,
          "notes": "Mission-driven organization (CZI, Arc, etc.)"
        },
        {
          "name": "remote_friendly",
          "keywords": ["remote", "hybrid", "async", "distributed team"],
          "points": 8,
          "notes": "Flexible work arrangements"
        },
        {
          "name": "technical_leadership",
          "keywords": ["CTO", "VP Eng", "technical", "engineering culture", "tech-first"],
          "points": 8,
          "notes": "Technically sophisticated leadership"
        }
      ]
    },
    "location_requirements": {
      "weight": 5,
      "description": "Location and visa considerations (lower weight than other factors)",
      "signals": [
        {
          "name": "bay_area",
          "keywords": ["San Francisco", "Palo Alto", "Menlo Park", "Mountain View", "Sunnyvale", "San Jose"],
          "points": 5,
          "notes": "SF Bay Area location"
        },
        {
          "name": "remote_us",
          "keywords": ["remote", "US timezone", "Pacific time", "ET"],
          "points": 5,
          "notes": "Remote US-based role"
        },
        {
          "name": "tn_visa",
          "keywords": ["TN", "Canadian", "visa sponsorship"],
          "points": 5,
          "notes": "TN visa eligible"
        }
      ]
    }
  },
  "weight_adjustments": {
    "description": "Manual adjustments to scoring based on strategic priorities",
    "decrease_immediate_comp_weight": true,
    "comp_weight_reduced_from": 20,
    "comp_weight_reduced_to": 5,
    "reason": "De-emphasize immediate compensation to focus on career value and impact"
  },
  "bonus_signals": {
    "description": "Additional points for exceptional alignment",
    "bonuses": [
      {
        "name": "scverse_experience",
        "keywords": ["Scanpy", "AnnData", "scvi-tools", "scverse", "single-cell"],
        "bonus_points": 10,
        "requires_category": "virtual_cell"
      },
      {
        "name": "agentic_ai",
        "keywords": ["agent", "MCP", "Model Context Protocol", "autonomous", "agentic"],
        "bonus_points": 8,
        "notes": "Scientific AI agents experience"
      },
      {
        "name": "mle_platform_building",
        "keywords": ["ML platform", "ML infrastructure", "data platform", "feature platform"],
        "bonus_points": 5,
        "notes": "Platform building experience"
      }
    ]
  },
  "filter_rules": {
    "description": "Hard filters that immediately disqualify roles",
    "hard_no": [
      {
        "name": "rule_based_only",
        "exclude_keywords": ["rule-based", "heuristic only", "no ML", "manual"],
        "reason": "Requires ML depth, not rule-based systems"
      },
      {
        "name": "non_technical_leadership",
        "exclude_keywords": ["non-technical manager", "non-technical lead"],
        "reason": "Needs technically sophisticated leadership"
      },
      {
        "name": "no_compute_budget",
        "exclude_keywords": ["no GPU", "CPU only", "limited compute"],
        "reason": "Requires compute resources for ML work"
      }
    ],
    "soft_no": [
      {
        "name": "testing_only",
        "exclude_keywords": ["A/B testing only", "experimentation only", "no model development"],
        "reason": "Want model development, not just testing"
      }
    ]
  },
  "output_schema": {
    "description": "Standard output format for scored leads",
    "fields": [
      "job_id",
      "company",
      "role_title",
      "location",
      "application_url",
      "raw_jd_text",
      "detected_signals",
      "category_scores",
      "total_score",
      "meets_threshold",
      "priority_level",
      "recommended_actions"
    ]
  }
}