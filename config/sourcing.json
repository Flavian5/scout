  "job_boards": {
    "linkedin": {
      "enabled": true,
      "search_template": "https://www.linkedin.com/jobs/search/?keywords={keywords}&location=San+Francisco+Bay+Area&f_TPR=r86400",
      "filters": [" posted today", "linkedinRecruiter"]
    },
    "wellfound": {
      "enabled": false,
      "search_template": "https://wellfound.com/jobs?query={keywords}&loc=San_Francisco",
      "notes": "Disabled - cookies stale"
    },
    "glassdoor": {
      "enabled": false,
      "notes": "Less relevant for senior roles"
    }
  },
  "search_parameters": {
    "recency_days": 7,
    "job_limit": 200,
    "location_filter": ["San Francisco", "Bay Area", "Seattle", "Remote", "San Jose", "Palo Alto"],
    "experience_level": ["Staff", "Lead"],
    "salary_minimum": 250000,
    "equity_include": true
  },
  "c2c_config": {
    "description": "Configuration for C2C contract job search",
    "enabled": true,
    "platforms": {
      "dice": {
        "enabled": true,
        "search_template": "https://www.dice.com/jobs?q={keywords}&l=San+Francisco%2C+CA",
        "filters": ["contract", "c2c", "corp-to-corp", "1099"],
        "priority": 5,
        "notes": "Fallback only - lower rates"
      },
      "linkedin": {
        "enabled": true,
        "search_template": "https://www.linkedin.com/jobs/search/?keywords={keywords}&contractType=corp&location=United+States",
        "filters": ["contract", "corp-to-corp"],
        "priority": 3
      },
      "wellfound": {
        "enabled": true,
        "search_template": "https://wellfound.com/remote/contract-jobs?query={keywords}",
        "priority": 4,
        "notes": "Lower priority - mostly startups with limited cash"
      },
      "toptal": {
        "enabled": true,
        "notes": "Premium freelance network - requires application",
        "priority": 4
      },
      "gunio": {
        "enabled": true,
        "notes": "Elite freelance developer network",
        "priority": 4
      },
      "braintrust": {
        "enabled": true,
        "notes": "Worker-owned network, high rates, C2C-friendly - vetting takes ~2 weeks",
        "priority": 1,
        "application_url": "https://braintrust.com/apply",
        "requires_application": true
      },
      "ateam": {
        "enabled": true,
        "notes": "Elite talent network, C2C available",
        "priority": 1,
        "application_url": "https://ateam.io/join",
        "requires_application": true
      },
      "upwork": {
        "enabled": false,
        "notes": "Lower rates, less relevant for Staff-level"
      }
    },
    "direct_networking": {
      "description": "Direct networking and outreach channels",
      "enabled": true,
      "channels": [
        {
          "name": "CTO Cold Outreach",
          "short_name": "CTO Outreach",
          "notes": "LinkedIn Sales Navigator - 50 InMails/month, target Series C+ companies",
          "priority": 1,
          "target_per_week": 20,
          "tool": "LinkedIn Sales Navigator",
          "cost": "$99/month"
        }
      ]
    },
